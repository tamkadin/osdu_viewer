# Flask runtime
FLASK_ENV=production
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# OSDU environment shared by Data Viewer and Access Control
OSDU_BASE_URL=https://osdu.example.com
OSDU_BASE_HOST=
OSDU_PARTITION_ID=osdu
OSDU_VERIFY_SSL=True
OSDU_TIMEOUT_SECONDS=30

# OSDU service paths
OSDU_ENTITLEMENTS_BASE_PATH=/api/entitlements/v2
OSDU_LEGAL_BASE_PATH=/api/legal/v1
OSDU_PARTITION_BASE_PATH=/api/partition/v1
OSDU_STORAGE_BASE_PATH=/api/storage/v2
OSDU_GROUP_SCAN_LIMIT=5000
OSDU_MAX_PAGE_SIZE=100

# Keycloak token endpoint
OSDU_TOKEN_ENDPOINT=https://keycloak.example.com/realms/osdu/protocol/openid-connect/token
OSDU_TOKEN_HOST=
OSDU_AUTH_BASE_URL=
OSDU_AUTH_REALM=

# Token mode: client_credentials or password
OSDU_TOKEN_GRANT_TYPE=client_credentials
OSDU_CLIENT_ID=datafier
OSDU_CLIENT_SECRET=change-me

# Optional refresh/shared token support
OSDU_REFRESH_TOKEN=
OSDU_SHARED_ACCESS_TOKEN=
OSDU_TOKEN_SCOPE=openid profile email
OSDU_TOKEN_DEFAULT_EXPIRES_SECONDS=3600

# Required only when OSDU_TOKEN_GRANT_TYPE=password
OSDU_USERNAME=
OSDU_PASSWORD=

# Optional Keycloak admin user listing override.
# Leave empty to use the service-account token from OSDU_CLIENT_ID.
OSDU_EXTERNAL_ADMIN_USERNAME=
OSDU_EXTERNAL_ADMIN_PASSWORD=
